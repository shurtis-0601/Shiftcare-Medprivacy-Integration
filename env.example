# ── Required ────────────────────────────────────────────────────────────────

# Google Cloud project ID
GCP_PROJECT_ID=your-gcp-project-id

# Google Drive folder IDs (get from the folder URL: .../folders/<ID>)
DRIVE_PENDING_FOLDER_ID=
DRIVE_QUARANTINE_FOLDER_ID=

# Google Sheets spreadsheet ID for the reference code map
REFERENCE_MAP_SHEET_ID=

# Email address that receives pipeline error/quarantine notifications
NOTIFICATION_EMAIL=admin@yourorganisation.com.au

# ShiftCare login credentials (used by the Playwright scraper)
SHIFTCARE_EMAIL=
SHIFTCARE_PASSWORD=


# ── OAuth2 credentials ───────────────────────────────────────────────────────

# Path to the OAuth2 client secrets file downloaded from Google Cloud Console
# (APIs & Services → Credentials → OAuth 2.0 Client IDs → Desktop app → Download JSON)
OAUTH_CLIENT_SECRETS_PATH=client_secrets.json

# Where the OAuth token is cached after first login (do NOT commit this file)
OAUTH_TOKEN_PATH=token.json


# ── Folder paths ─────────────────────────────────────────────────────────────

# Folder where the scraper saves raw PDFs and the pipeline reads them from
INPUT_FOLDER=input

# Directories used by run_local.py
PIPELINE_INPUT_DIR=input
PIPELINE_PROCESSED_DIR=processed
PIPELINE_LOG_DIR=logs


# ── Optional — ShiftCare scraper overrides ───────────────────────────────────

# Navigate directly to the Events page instead of using the sidebar menu.
# Find this URL by clicking Reports → Events in your browser.
# SC_EVENTS_URL=https://app.shiftcare.com/reports/events

# Sidebar menu labels (change if ShiftCare uses different text in your locale)
# SC_NAV_REPORTS_TEXT=Reports
# SC_NAV_EVENTS_TEXT=Events

# CSS selector for participant links on the Events page.
# Run with SHIFTCARE_HEADLESS=false and check screenshots/ to find the right selector.
# SC_SEL_PARTICIPANT_ROW=table tbody tr a

# Text of the Export button on a participant's progress-notes page
# SC_EXPORT_BTN_TEXT=Export

# Full URL to the Download Center
# SC_DOWNLOAD_CENTER_URL=https://app.shiftcare.com/users/report/download_center

# CSS selectors for Download Center rows, status cell, and Download button
# SC_SEL_DC_ROW=table tbody tr
# SC_SEL_DC_STATUS=td.status
# SC_SEL_DC_DOWNLOAD=a:has-text('Download')

# Status text that means the export is ready to download
# SC_DC_COMPLETED_TEXT=Completed

# Polling interval (ms) and max attempts while waiting for Completed status
# SC_DC_POLL_INTERVAL_MS=3000
# SC_DC_POLL_MAX_ATTEMPTS=40

# Set to false to run the browser visibly (useful for debugging selectors)
# SHIFTCARE_HEADLESS=true

# Directory where the scraper saves debug screenshots
# SCREENSHOT_DIR=./screenshots

# Navigation timeout in milliseconds
# SC_NAV_TIMEOUT_MS=30000

# Login form selectors (override if ShiftCare changes its HTML)
# SC_SEL_EMAIL=input[type='email']
# SC_SEL_PASSWORD=input[type='password']
# SC_SEL_SUBMIT=button[type='submit']


# ── Optional — pipeline settings ─────────────────────────────────────────────

# Override the ShiftCare base URL (default: https://app.shiftcare.com)
# SHIFTCARE_BASE_URL=https://app.shiftcare.com

# Timezone for determining "yesterday" (default: Australia/Melbourne)
# TIMEZONE=Australia/Melbourne

# Google Workspace email the service account impersonates for notifications.
# Leave blank to disable email notifications.
# GMAIL_SENDER_EMAIL=

# Google Drive file ID of the master PII CSV (carers, orgs, locations).
# Leave blank to skip (non-fatal).
# PII_CSV_FILE_ID=

# Google Drive folder ID for the pipeline audit log
# DRIVE_AUDIT_FOLDER_ID=

# Number of DLP findings before quarantining (0 = zero tolerance)
# QUARANTINE_FINDING_THRESHOLD=0
