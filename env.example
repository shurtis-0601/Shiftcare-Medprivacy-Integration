# ── Required ────────────────────────────────────────────────────────────────

# Google Cloud project that owns the Cloud Function, Secret Manager, and Logging
GCP_PROJECT_ID=your-gcp-project-id

# ShiftCare API key — store in Secret Manager for production; set here for local testing
# Secret Manager secret name: shiftcare-api-key
SHIFTCARE_API_KEY=

# Google Drive folder IDs (get from the folder URL: .../folders/<ID>)
DRIVE_PENDING_FOLDER_ID=
DRIVE_QUARANTINE_FOLDER_ID=

# Google Sheets spreadsheet ID for the reference code map (from the sheet URL)
# This sheet must be in a SEPARATE secure location, not in the VA working folder
REFERENCE_MAP_SHEET_ID=

# Email address that receives pipeline error/quarantine notifications
NOTIFICATION_EMAIL=admin@yourorganisation.com.au

# Google Drive file ID of the master PII CSV (Type,Name columns — same format as
# medprivacy.py's pii_database.csv). Used to redact carers, organizations, and
# locations that are not available from the ShiftCare API.
# Leave blank to skip (non-fatal — pipeline runs without it).
# Share the file with the service account as Viewer.
PII_CSV_FILE_ID=


# ── Optional ─────────────────────────────────────────────────────────────────

# The Google Workspace email address the service account impersonates to send mail.
# Requires domain-wide delegation to be configured (see deploy.sh notes).
# Leave blank to disable email notifications (errors still go to Cloud Logging).
GMAIL_SENDER_EMAIL=

# Override the ShiftCare base URL (default: https://app.shiftcare.com)
# SHIFTCARE_BASE_URL=https://app.shiftcare.com

# Timezone for determining "yesterday" (default: Australia/Melbourne)
# TIMEZONE=Australia/Melbourne

# GCP region for DLP/SDP (not used — here for reference)
# DLP_LOCATION=global


# ── Local testing only ───────────────────────────────────────────────────────

# Path to a service account JSON key file (do NOT use in production — use ADC)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
